INSERT INTO DDMTEMPLATE VALUES(2,0,'34a12dad-0f75-903c-24b6-8d0eddfdfb96',31632,20119,16796623585306,20095,NULL,20095,NULL,'2024-05-13 14:37:48.613000','2026-04-10 17:40:36.134000',31631,0,31505,'CUSTOM-FACET-COMPACT-FTL','1.2','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Name language-id="en_US">Compact Layout (Multiselect)</Name><Name language-id="ar_SA">\u062a\u062e\u0637\u064a\u0637 \u0635\u063a\u064a\u0631 (\u062a\u062d\u062f\u064a\u062f \u0645\u062a\u0639\u062f\u062f)</Name><Name language-id="ca_ES">Disposici\u00f3 compacta (selecci\u00f3 m\u00faltiple)</Name><Name language-id="zh_CN">\u7d27\u51d1\u5e03\u5c40\uff08\u591a\u9009\uff09</Name><Name language-id="nl_NL">Compacte lay-out (meervoudige selectie)</Name><Name language-id="fi_FI">Tiivis asettelu (monivalinta)</Name><Name language-id="fr_FR">Disposition compacte (s\u00e9lection multiple)</Name><Name language-id="de_DE">Kompaktes Layout (Mehrfachauswahl)</Name><Name language-id="hu_HU">Kompakt elrendez\u00e9s (t\u00f6bbv\u00e1laszt\u00f3s)</Name><Name language-id="ja_JP">\u30b3\u30f3\u30d1\u30af\u30c8\u30ec\u30a4\u30a2\u30a6\u30c8 (\u8907\u6570\u9078\u629e)</Name><Name language-id="pt_BR">Layout compacto (Multisele\u00e7\u00e3o)</Name><Name language-id="es_ES">Dise\u00f1o compacto (selecci\u00f3n m\u00faltiple)</Name><Name language-id="sv_SE">Kompakt layout (flera val)</Name><Name language-id="zh_TW">Compact Layout (Multiselect)</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Description language-id="en_US">Display terms as a list of links.</Description><Description language-id="ar_SA">\u0639\u0631\u0636 \u0627\u0644\u0645\u0635\u0637\u0644\u062d\u0627\u062a \u0643\u0642\u0627\u0626\u0645\u0629 \u0645\u0646 \u0627\u0644\u0631\u0648\u0627\u0628\u0637.</Description><Description language-id="ca_ES">Mostra els termes com una llista d''enlla\u00e7os.</Description><Description language-id="zh_CN">\u5c06\u641c\u7d22\u8bcd\u663e\u793a\u4e3a\u94fe\u63a5\u5217\u8868\u3002</Description><Description language-id="nl_NL">Termen weergeven als een lijst met links.</Description><Description language-id="fi_FI">N\u00e4yt\u00e4 termit linkkien luettelona.</Description><Description language-id="fr_FR">Afficher les termes sous la forme de liste de liens.</Description><Description language-id="de_DE">Begriffe als Linkliste anzeigen.</Description><Description language-id="hu_HU">Jelen\u00edtse meg a kifejez\u00e9seket hivatkoz\u00e1sok list\u00e1jak\u00e9nt.</Description><Description language-id="ja_JP">\u7528\u8a9e\u3092\u30ea\u30f3\u30af\u30ea\u30b9\u30c8\u3068\u3057\u3066\u8868\u793a\u3057\u307e\u3059\u3002</Description><Description language-id="pt_BR">Exibir termos como uma lista de links.</Description><Description language-id="es_ES">Muestra t\u00e9rminos como una lista de enlaces.</Description><Description language-id="sv_SE">Visa villkoren som en lista med l\u00e4nkar.</Description><Description language-id="zh_TW">\u986f\u793a\u641c\u5c0b\u5b57\u8a5e\u70ba\u9023\u7d50\u5217\u8868\u3002</Description></root>','display',NULL,'ftl','<@liferay_ui["panel-container"]\u000a\u0009extended=true\u000a\u0009id="${namespace + ''facetCustomPanelContainer''}"\u000a\u0009markupView="lexicon"\u000a\u0009persistState=true\u000a>\u000a\u0009<@liferay_ui.panel\u000a\u0009\u0009collapsible=true\u000a\u0009\u0009cssClass="search-facet"\u000a\u0009\u0009id="${namespace + ''facetCustomPanel''}"\u000a\u0009\u0009markupView="lexicon"\u000a\u0009\u0009persistState=true\u000a\u0009\u0009title="${customFacetDisplayContext.getDisplayCaption()}"\u000a\u0009>\u000a\u0009\u0009<#if !customFacetDisplayContext.isNothingSelected()>\u000a\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009cssClass="btn-unstyled c-mb-4 facet-clear-btn"\u000a\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009id="${namespace + ''facetCustomClear''}"\u000a\u0009\u0009\u0009\u0009onClick="Liferay.Search.FacetUtil.clearSelections(event);"\u000a\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009<strong>${languageUtil.get(locale, "clear")}</strong>\u000a\u000a\u0009\u0009\u0009\u0009<span class="sr-only">\u000a\u0009\u0009\u0009\u0009\u0009${languageUtil.format(locale, ''x-filter'', ''custom-facet-portlet-instance-configuration-name'')}\u000a\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009</#if>\u000a\u000a\u0009\u0009<ul class="list-unstyled">\u000a\u0009\u0009\u0009<#if entries?has_content>\u000a\u0009\u0009\u0009\u0009<#list entries as entry>\u000a\u0009\u0009\u0009\u0009\u0009<li>\u000a\u0009\u0009\u0009\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClass="facet-term btn-unstyled ${(entry.isSelected())?then(''facet-term-selected'', ''facet-term-unselected'')} term-name"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009data\-term\-id="${entry.getBucketText()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009disabled="true"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009onClick="Liferay.Search.FacetUtil.changeSelection(event);"\u000a\u0009\u0009\u0009\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if entry.isSelected()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<strong><@liferay_ui["message"] key="${htmlUtil.escape(entry.getBucketText())}" /></strong>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_ui["message"] key="${htmlUtil.escape(entry.getBucketText())}" />\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if entry.isFrequencyVisible()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<small class="term-count">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009(${entry.getFrequency()})\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</small>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009\u0009\u0009\u0009</li>\u000a\u0009\u0009\u0009\u0009</#list>\u000a\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009<#if customFacetDisplayContext.isShowInputRange()>\u000a\u0009\u0009\u0009\u0009<#if (customFacetDisplayContext.getAggregationType() == "range") || (customFacetDisplayContext.getAggregationType() == "dateRange")>\u000a\u0009\u0009\u0009\u0009\u0009<li class="facet-value">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClass="facet-term btn-unstyled ${(customRangeBucketDisplayContext.isSelected())?then(''facet-term-selected'', ''facet-term-unselected'')} term-name"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009data\-term\-id="${htmlUtil.escape(customRangeBucketDisplayContext.getBucketText())}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009disabled="true"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009id="${namespace}${customRangeBucketDisplayContext.getBucketText()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009name="${namespace}${customRangeBucketDisplayContext.getBucketText()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if customRangeBucketDisplayContext.isSelected()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<strong><@liferay_ui["message"] key="${htmlUtil.escape(customRangeBucketDisplayContext.getBucketText())}" /></strong>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_ui["message"] key="${htmlUtil.escape(customRangeBucketDisplayContext.getBucketText())}" />\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if customRangeBucketDisplayContext.isSelected()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<small class="term-count">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009(${customRangeBucketDisplayContext.getFrequency()})\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</small>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</@clay.button>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_aui.script>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009document.getElementById(''${namespace}${customRangeBucketDisplayContext.getBucketText()}'').onclick = function(event) {\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009if ("${customFacetDisplayContext.getAggregationType()}" == "dateRange") {\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009Liferay.Search.FacetUtil.changeSelection(event);\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009if ("${customFacetDisplayContext.getAggregationType()}" == "range") {\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009event.preventDefault();\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009const customRangeElement = document.getElementById(''${namespace}customRange'');\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009if (customRangeElement && customRangeElement.classList.contains(''hide'')) {\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009customRangeElement.classList.remove(''hide'');\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009else if (Liferay.Search.FacetUtil.isCustomRangeValid(event)) {\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009Liferay.Search.FacetUtil.changeSelection(event);\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009</@liferay_aui.script>\u000a\u0009\u0009\u0009\u0009\u0009</li>\u000a\u0009\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009\u0009<#if customFacetDisplayContext.getAggregationType() == "range">\u000a\u0009\u0009\u0009\u0009\u0009<div class="${(!customRangeBucketDisplayContext.isSelected())?then("hide", "")} date-custom-range" id="${namespace}customRange">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<div class="col-md-6" id="${namespace}customRangeFrom">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_aui["field-wrapper"]>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_aui.input\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009label="from"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009id="fromInput"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009name="fromInput"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009type="number"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009value=customFacetDisplayContext.getFromParameterValue()\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</@>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009<div class="col-md-6" id="${namespace}customRangeTo">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_aui["field-wrapper"]>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_aui.input\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009label="to"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009id="toInput"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009name="toInput"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009type="number"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009value=customFacetDisplayContext.getToParameterValue()\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009\u0009\u000