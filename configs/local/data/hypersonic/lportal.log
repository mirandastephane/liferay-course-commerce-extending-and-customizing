INSERT INTO DDMTEMPLATEVERSION VALUES(0,0,94683,20119,16796623585306,20095,NULL,'2025-05-07 00:47:23.712000',31659,0,31660,'1.3','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Name language-id="en_US">Radio Layout</Name><Name language-id="ar_SA">\u0645\u062e\u0637\u0637 \u0627\u0644\u0631\u0627\u062f\u064a\u0648</Name><Name language-id="ca_ES">Disposici\u00f3 de r\u00e0dio</Name><Name language-id="zh_CN">\u5355\u9009\u6309\u94ae\u5e03\u5c40</Name><Name language-id="nl_NL">Keuzerondjeslay-out</Name><Name language-id="fi_FI">Valintapainikeasettelu</Name><Name language-id="fr_FR">Disposition radio</Name><Name language-id="de_DE">Optionsfelderlayout</Name><Name language-id="hu_HU">R\u00e1di\u00f3 elrendez\u00e9s</Name><Name language-id="ja_JP">\u30e9\u30b8\u30aa\u306e\u30ec\u30a4\u30a2\u30a6\u30c8</Name><Name language-id="pt_BR">Layout de r\u00e1dio</Name><Name language-id="es_ES">Dise\u00f1o de radio</Name><Name language-id="sv_SE">Radio-layout</Name><Name language-id="zh_TW">\u55ae\u9078\u6309\u9215\u4f48\u5c40</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Description language-id="en_US">Display terms with radio buttons.</Description><Description language-id="ar_SA">\u0639\u0631\u0636 \u0627\u0644\u0645\u0635\u0637\u0644\u062d\u0627\u062a \u0628\u0623\u0632\u0631\u0627\u0631 \u0627\u062e\u062a\u064a\u0627\u0631.</Description><Description language-id="ca_ES">Mostra els termes amb botons de r\u00e0dio.</Description><Description language-id="zh_CN">\u5c06\u641c\u7d22\u8bcd\u663e\u793a\u4e3a\u5355\u9009\u6309\u94ae\u3002</Description><Description language-id="nl_NL">Termen weergeven met checkboxen.</Description><Description language-id="fi_FI">N\u00e4yt\u00e4 termit radiopainikkeina.</Description><Description language-id="fr_FR">Afficher les termes avec les boutons radio.</Description><Description language-id="de_DE">Begriffe mit Optionsfeldern anzeigen.</Description><Description language-id="hu_HU">Jelen\u00edtse meg a kifejez\u00e9seket r\u00e1di\u00f3gombokkal.</Description><Description language-id="ja_JP">\u7528\u8a9e\u3092\u30e9\u30b8\u30aa\u30dc\u30bf\u30f3\u4ed8\u304d\u3067\u8868\u793a\u3057\u307e\u3059\u3002</Description><Description language-id="pt_BR">Exibir termos como bot\u00f5es de r\u00e1dio.</Description><Description language-id="es_ES">Muestra t\u00e9rminos con botones de radio.</Description><Description language-id="sv_SE">Visa villkoren med radioknappar.</Description><Description language-id="zh_TW">\u4ee5\u55ae\u9078\u6309\u9375\u986f\u793a\u641c\u5c0b\u5b57\u8a5e\u3002</Description></root>','ftl','<@liferay_ui["panel-container"]\u000a\u0009extended=true\u000a\u0009id="${namespace + ''facetModifiedPanelContainer''}"\u000a\u0009markupView="lexicon"\u000a\u0009persistState=true\u000a>\u000a\u0009<@liferay_ui.panel\u000a\u0009\u0009collapsible=true\u000a\u0009\u0009cssClass="search-facet"\u000a\u0009\u0009id="${namespace + ''facetModifiedPanel''}"\u000a\u0009\u0009markupView="lexicon"\u000a\u0009\u0009persistState=true\u000a\u0009\u0009title="last-modified"\u000a\u0009>\u000a\u0009\u0009<#if !modifiedFacetDisplayContext.isNothingSelected()>\u000a\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009cssClass="btn-unstyled c-mb-4 facet-clear-btn"\u000a\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009id="${namespace + ''facetModifiedClear''}"\u000a\u0009\u0009\u0009\u0009onClick="Liferay.Search.FacetUtil.clearSelections(event);"\u000a\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009<strong>${languageUtil.get(locale, "clear")}</strong>\u000a\u000a\u0009\u0009\u0009\u0009<span class="sr-only">\u000a\u0009\u0009\u0009\u0009\u0009${languageUtil.format(locale, ''x-filter'', ''modified-facet-portlet-instance-configuration-name'')}\u000a\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009</#if>\u000a\u000a\u0009\u0009<ul class="list-unstyled modified">\u000a\u0009\u0009\u0009<#if entries?has_content>\u000a\u0009\u0009\u0009\u0009<#list entries as entry>\u000a\u0009\u0009\u0009\u0009\u0009<li class="facet-value">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<div class="custom-control custom-radio">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<label class="facet-checkbox-label" for="${namespace}${entry.getBucketText()}">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_ui.csp>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<input\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009${(entry.isSelected())?then("checked", "")}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009class="custom-control-input facet-term"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009disabled\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009id="${namespace}${entry.getBucketText()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009name="${namespace}${entry.getBucketText()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009onChange=''${"window.location.href = \"${entry.getFilterValue()}\";"}''\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009role="radio"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009type="radio"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</@liferay_ui.csp>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="custom-control-label term-name ${(entry.isSelected())?then(''facet-term-selected'', ''facet-term-unselected'')}">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="custom-control-label-text">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if entry.isSelected()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<strong><@liferay_ui["message"] key="${htmlUtil.escape(entry.getBucketText())}" /></strong>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_ui["message"] key="${htmlUtil.escape(entry.getBucketText())}" />\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<small class="term-count">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009(${entry.getFrequency()})\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</small>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</label>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009\u0009</li>\u000a\u0009\u0009\u0009\u0009</#list>\u000a\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009<li class="facet-value">\u000a\u0009\u0009\u0009\u0009<div class="custom-control custom-radio">\u000a\u0009\u0009\u0009\u0009\u0009<label class="facet-checkbox-label" for="${namespace}${customRangeBucketDisplayContext.getBucketText()}">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_ui.csp>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<input\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009${(customRangeBucketDisplayContext.isSelected())?then("checked", "")}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009class="custom-control-input facet-term"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009disabled\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009id="${namespace}${customRangeBucketDisplayContext.getBucketText()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009name="${namespace}${customRangeBucketDisplayContext.getBucketText()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009onChange=''${"window.location.href = \"${customRangeBucketDisplayContext.g