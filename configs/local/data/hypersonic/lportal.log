INSERT INTO DDMTEMPLATE VALUES(1,0,'a77e0f05-b9e5-6a6b-c6eb-bc5d8c875190',31581,20119,16796623585306,20095,NULL,20095,NULL,'2024-05-13 14:37:46.864000','2026-04-10 17:40:35.655000',20006,0,31505,'ASSET-TAGS-NAVIGATION-COLOR-BY-POPULARITY-FTL','1.1','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Name language-id="en_US">Color by Popularity</Name><Name language-id="ar_SA">\u0627\u0644\u0623\u0644\u0648\u0627\u0646 \u062d\u0633\u0628 \u0627\u0644\u0623\u0648\u0644\u0648\u064a\u0629</Name><Name language-id="ca_ES">Color per popularitat</Name><Name language-id="zh_CN">\u53d7\u6b22\u8fce\u7684\u989c\u8272</Name><Name language-id="nl_NL">Kleur op populariteit</Name><Name language-id="fi_FI">V\u00e4ri suosion mukaan</Name><Name language-id="fr_FR">Couleur par popularit\u00e9</Name><Name language-id="de_DE">Nach Popularit\u00e4t f\u00e4rben</Name><Name language-id="hu_HU">Sz\u00edn n\u00e9pszer\u0171s\u00e9g alapj\u00e1n</Name><Name language-id="ja_JP">\u983b\u51fa\u5ea6\u306b\u3088\u308a\u8272\u5206\u3051\u3059\u308b</Name><Name language-id="pt_BR">Colorir por Popularidade</Name><Name language-id="es_ES">Color por popularidad</Name><Name language-id="sv_SE">F\u00e4rga efter popularitet</Name><Name language-id="zh_TW">\u4ee5\u71b1\u9580\u5ea6\u6a19\u8272</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Description language-id="en_US">Displays asset tags colored by popularity: red (high), yellow (medium), and green (low).</Description><Description language-id="ar_SA">\u064a\u0639\u0631\u0636 \u0639\u0644\u0627\u0645\u0627\u062a \u0627\u0644\u0623\u0635\u0648\u0644 \u0627\u0644\u0645\u0644\u0648\u0646\u0629 \u062d\u0633\u0628 \u0627\u0644\u0623\u0648\u0644\u0648\u064a\u0629: \u0627\u0644\u0623\u062d\u0645\u0631 (\u0645\u0631\u062a\u0641\u0639) \u0648\u0627\u0644\u0623\u0635\u0641\u0631 (\u0645\u062a\u0648\u0633\u0637) \u0648\u0627\u0644\u0623\u062e\u0636\u0631 (\u0645\u0646\u062e\u0641\u0636).</Description><Description language-id="ca_ES">Mostra les etiquetes per colors segons popularitat: vermell (alta), groga (mitjana) i verda (baixa).</Description><Description language-id="zh_CN">\u663e\u793a\u8d44\u6e90\u6807\u7b7e\u989c\u8272\u7b49\u7ea7\uff1a \u7ea2\u8272 (\u9ad8), \u9ec4\u8272 (\u4e2d), \u7eff\u8272 (\u4f4e).</Description><Description language-id="nl_NL">Toon content labels volgens populariteit: rood (hoog), geel (midden) en groen (laag).</Description><Description language-id="fi_FI">N\u00e4ytt\u00e4\u00e4 sis\u00e4lt\u00f6tageja, mitk\u00e4 on v\u00e4ritetty suosion mukaan: punainen (korkea), keltainen (keskiverto) ja virhe\u00e4 (alhainen)</Description><Description language-id="fr_FR">Affiche les \u00e9tiquettes d''asset colori\u00e9es par popularit\u00e9: rouge (\u00e9lev\u00e9), jaune (moyen), et vert (bas).</Description><Description language-id="de_DE">Schlagw\u00f6rter nach Popularit\u00e4t f\u00e4rben: Rot (hoch), gelb (mittel), gr\u00fcn (niedrig).</Description><Description language-id="hu_HU">Megjelen\u00edti a tartalom c\u00edmk\u00e9ket n\u00e9pszer\u0171s\u00e9g szerint sz\u00ednezve: v\u00f6r\u00f6s (magas), s\u00e1rga (k\u00f6zepes), \u00e9s z\u00f6ld (alacsony).</Description><Description language-id="ja_JP">\u30a2\u30bb\u30c3\u30c8\u30bf\u30b0\u3092\u4eba\u6c17\u9806\u306b\u8868\u793a\u3059\u308b:\u8d64(\u9ad8\u3044)\u3001\u9ec4\u8272\uff08\u666e\u901a)\u3001\u7dd1\uff08\u4f4e\u3044\uff09</Description><Description language-id="pt_BR">Exibe marcadores coloridos por popularidade: vermelho (alta), amarelo (m\u00e9dia) e verde (baixa).</Description><Description language-id="es_ES">Muestra las etiquetas de contenido coloreadas seg\u00fan su popularidad : rojo (alta), amarilla (media) y verde (baja).</Description><Description language-id="sv_SE">Visar tillg\u00e5ngstaggar f\u00e4rgade efter popularitet: r\u00f6d (h\u00f6g), gul (medelh\u00f6g) och gr\u00f6n (l\u00e5g).</Description><Description language-id="zh_TW">\u986f\u793a\u6709\u984f\u8272\u7684\u8cc7\u7522\u6a19\u7c64\u4f9d\u71b1\u9580\u5ea6\uff1a\u7d05(\u9ad8)\u3001\u9ec3(\u4e2d)\u3001\u7da0(\u4f4e)\u3002</Description></root>','display',NULL,'ftl','<#if entries?has_content>\u000a\u0009<ul class="tag-items tag-list">\u000a\u0009\u0009<#assign\u000a\u0009\u0009\u0009scopeGroupId = getterUtil.getLong(scopeGroupId, themeDisplay.getScopeGroupId())\u000a\u0009\u0009\u0009classNameId = getterUtil.getLong(classNameId, 0)\u000a\u0009\u0009\u0009scopedAssetCounts = assetTagsNavigationDisplayContext.getScopedAssetCounts()\u000a\u000a\u0009\u0009\u0009maxCount = 1\u000a\u0009\u0009\u0009minCount = 1\u000a\u0009\u0009/>\u000a\u000a\u0009\u0009<#list entries as entry>\u000a\u0009\u0009\u0009<#if scopedAssetCounts??>\u000a\u0009\u0009\u0009\u0009<#assign assetCount = scopedAssetCounts[entry.getName()] />\u000a\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009<#assign assetCount = entry.getAssetCount() />\u000a\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009<#if (assetCount > 0) || getterUtil.getBoolean(showZeroAssetCount)>\u000a\u0009\u0009\u0009\u0009<#assign\u000a\u0009\u0009\u0009\u0009\u0009maxCount = liferay.max(maxCount, assetCount)\u000a\u0009\u0009\u0009\u0009\u0009minCount = liferay.min(minCount, assetCount)\u000a\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009</#if>\u000a\u0009\u0009</#list>\u000a\u000a\u0009\u0009<#assign multiplier = 1 />\u000a\u000a\u0009\u0009<#if maxCount != minCount>\u000a\u0009\u0009\u0009<#assign multiplier = 3 / (maxCount - minCount) />\u000a\u0009\u0009</#if>\u000a\u000a\u0009\u0009<#list entries as entry>\u000a\u0009\u0009\u0009<#if scopedAssetCounts??>\u000a\u0009\u0009\u0009\u0009<#assign assetCount = scopedAssetCounts[entry.getName()] />\u000a\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009<#assign assetCount = entry.getAssetCount() />\u000a\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009<#if (assetCount > 0) || getterUtil.getBoolean(showZeroAssetCount)>\u000a\u0009\u0009\u0009\u0009<li class="taglib-asset-tags-summary">\u000a\u0009\u0009\u0009\u0009\u0009<#assign popularity = (maxCount - (maxCount - (assetCount - minCount))) * multiplier />\u000a\u000a\u0009\u0009\u0009\u0009\u0009<#if popularity < 1>\u000a\u0009\u0009\u0009\u0009\u0009\u0009<#assign displayType = "success" />\u000a\u0009\u0009\u0009\u0009\u0009<#elseif (popularity >= 1) && (popularity < 2)>\u000a\u0009\u0009\u0009\u0009\u0009\u0009<#assign displayType = "warning" />\u000a\u0009\u0009\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009\u0009\u0009<#assign displayType = "danger" />\u000a\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<#assign tagURL = renderResponse.createRenderURL() />\u000a\u000a\u0009\u0009\u0009\u0009\u0009${tagURL.setParameter("resetCur", "true")}\u000a\u0009\u0009\u0009\u0009\u0009${tagURL.setParameter("tag", entry.getName())}\u000a\u000a\u0009\u0009\u0009\u0009\u0009<a class="label label-${displayType} tag" href="${tagURL}">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<span class="label-item label-item-expand">${entry.getName()}</span>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009<#if assetCount?? && getterUtil.getBoolean(showAssetCount)>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="label-item label-item-after tag-asset-count">(${assetCount})</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009</a>\u000a\u0009\u0009\u0009\u0009</li>\u000a\u0009\u0009\u0009</#if>\u000a\u0009\u0009</#list>\u000a\u0009</ul>\u000a</#if>','0','0',31582,NULL,NULL,'a77e0f05-b9e5-6a6b-c6eb-bc5d8c875190')
