INSERT INTO DDMTEMPLATEVERSION VALUES(0,0,94672,20119,16796623585306,20095,NULL,'2024-05-13 14:37:52.139000',31722,0,31723,'1.1','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Name language-id="en_US">Basic</Name><Name language-id="ar_SA">\u0623\u0633\u0627\u0633\u064a</Name><Name language-id="ca_ES">B\u00e0sic</Name><Name language-id="zh_CN">\u57fa\u672c\u7684</Name><Name language-id="nl_NL">Basis</Name><Name language-id="fi_FI">Perus</Name><Name language-id="fr_FR">Basique</Name><Name language-id="de_DE">Einfach</Name><Name language-id="hu_HU">Egyszer\u0171</Name><Name language-id="ja_JP">\u901a\u5e38\u306e\u691c\u7d22\u306b\u623b\u308b</Name><Name language-id="pt_BR">B\u00e1sico</Name><Name language-id="es_ES">B\u00e1sico</Name><Name language-id="sv_SE">Standard</Name><Name language-id="zh_TW">\u57fa\u672c</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Description language-id="en_US">Displays titles, authors, and abstracts compactly for blog entries.</Description><Description language-id="ar_SA">\u064a\u0639\u0631\u0636 \u0627\u0644\u0639\u0646\u0627\u0648\u064a\u0646 \u0648\u0627\u0644\u0645\u0624\u0644\u0641\u064a\u0646 \u0648\u0627\u0644\u0645\u0644\u062e\u0635\u0627\u062a \u0644\u0625\u062f\u062e\u0627\u0644\u0627\u062a \u0627\u0644\u0645\u062f\u0648\u0646\u0627\u062a \u0628\u0634\u0643\u0644 \u0645\u0636\u063a\u0648\u0637.</Description><Description language-id="ca_ES">Mostra els titles, autors i resums de forma compacta per les entrades del blog.</Description><Description language-id="zh_CN">\u7b80\u4ecb\u663e\u793a\u535a\u5ba2\u7684\u540d\u5b57\uff0c\u4f5c\u8005\u548c\u6458\u8981\u3002</Description><Description language-id="nl_NL">Geeft titels, auteurs en samenvatting compact weer voor blogs.</Description><Description language-id="fi_FI">N\u00e4ytt\u00e4\u00e4 blogien otsikot, tekij\u00e4t ja lyhenteet lyhyesti</Description><Description language-id="fr_FR">Affiche titres, auteurs, et abstraits de mani\u00e8re compacte pour les entr\u00e9es de blog.</Description><Description language-id="de_DE">Kompakte Darstellung von Titel, Autoren und Kurzfassungen f\u00fcr Blogeintr\u00e4ge.</Description><Description language-id="hu_HU">Megjelen\u00edti kompakt m\u00f3don a c\u00edmeket, szerz\u0151ket \u00e9s kivonatokat a blog bejegyz\u00e9sekhez.</Description><Description language-id="ja_JP">\u30bf\u30a4\u30c8\u30eb\u3001\u4f5c\u6210\u8005\u3001\u8981\u7d04\u306f\u3001\u30d6\u30ed\u30b0\u30a8\u30f3\u30c8\u30ea\u30fc\u7528\u306b\u5c0f\u3055\u304f\u307e\u3068\u3081\u3089\u308c\u307e\u3059</Description><Description language-id="pt_BR">Exibe t\u00edtulos, autores e resumos compactamente para posts de blog.</Description><Description language-id="es_ES">Muestra de forma compacta t\u00edtulos, autores y res\u00famenes para las entradas del blog.</Description><Description language-id="sv_SE">Visa rubriker, f\u00f6rfattare och sammanfattningar kompakt f\u00f6r blogginl\u00e4gg.</Description><Description language-id="zh_TW">\u70ba\u90e8\u843d\u683c\u689d\u76ee\u7dca\u5bc6\u5730\u986f\u793a\u6a19\u984c\u3001\u4f5c\u8005\u8207\u6458\u8981\u3002</Description></root>','ftl','<#assign count = 0 />\u000a\u000a<div class="container-fluid container-fluid-max-xl text-center">\u000a\u0009<div class="p-3 row">\u000a\u0009\u0009<#if entries?has_content>\u000a\u0009\u0009\u0009<#list entries as curCommerceAddress>\u000a\u0009\u0009\u0009\u0009<div class="col-md-4 text-left">\u000a\u0009\u0009\u0009\u0009\u0009<#assign\u000a\u0009\u0009\u0009\u0009\u0009\u0009editURL = commerceAddressDisplayContext.getEditCommerceAddressURL(curCommerceAddress.getCommerceAddressId())\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009deleteURL = commerceAddressDisplayContext.getDeleteCommerceAddressURL(curCommerceAddress.getCommerceAddressId())\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009editButtonValue = languageUtil.get(request, "edit")\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009removeButtonValue = languageUtil.get(request, "remove")\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009commerceCountry = curCommerceAddress.getCommerceCountry()\u000a\u0009\u0009\u0009\u0009\u0009/>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<h2><strong>${htmlUtil.escape(curCommerceAddress.getName())}</strong></h2>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<h3>${htmlUtil.escape(curCommerceAddress.getStreet1())}</h3>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<h3>${htmlUtil.escape(curCommerceAddress.getZip())}, ${htmlUtil.escape(curCommerceAddress.getCity())}</h3>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<#if country??>\u000a\u0009\u0009\u0009\u0009\u0009\u0009<h3>${htmlUtil.escape(country.getName(themeDisplay.getLanguageId()))}</h3>\u000a\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<div class="pt-4 row">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_aui.button\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClass="btn-lg"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009href="${editURL}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009name="editAddressButton"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009value="${editButtonValue}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_aui.button\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClass="btn-lg"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009href="${deleteURL}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009name="removeAddressButton"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009value="${removeButtonValue}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009</div>\u000a\u000a\u0009\u0009\u0009\u0009<#assign count = count + 1 />\u000a\u000a\u0009\u0009\u0009\u0009<#if count gte 3>\u000a\u0009\u0009\u0009\u0009\u0009</div>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<div class="p-3 row">\u000a\u000a\u0009\u0009\u0009\u0009\u0009<#assign count = 0 />\u000a\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009</#list>\u000a\u0009\u0009</#if>\u000a\u0009</div>\u000a\u000a\u0009<div class="p-0 pb-1 pt-5 row">\u000a\u0009\u0009<#assign addButtonValue = languageUtil.get(request, "add-address") />\u000a\u000a\u0009\u0009<@liferay_aui.button\u000a\u0009\u0009\u0009cssClass="btn-lg btn-primary"\u000a\u0009\u0009\u0009href="${commerceAddressDisplayContext.getAddCommerceAddressURL()}"\u000a\u0009\u0009\u0009name="addAddressButton"\u000a\u0009\u0009\u0009value="${addButtonValue}"\u000a\u0009\u0009/>\u000a\u0009</div>\u000a</div>',0,20095,NULL,'2024-05-13 14:37:52.139000')
