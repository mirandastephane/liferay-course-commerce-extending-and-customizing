INSERT INTO DDMTEMPLATEVERSION VALUES(0,0,94676,20119,16796623585306,20095,NULL,'2025-05-07 00:47:23.485000',31618,0,31628,'1.4','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Name language-id="en_US">Vocabulary Layout</Name><Name language-id="ar_SA">\u0645\u062e\u0637\u0637 \u0627\u0644\u0645\u0641\u0631\u062f\u0627\u062a</Name><Name language-id="ca_ES">Disposici\u00f3 del vocabulari</Name><Name language-id="zh_CN">\u8bcd\u6c47\u5e03\u5c40</Name><Name language-id="nl_NL">Indeling woordenlijst</Name><Name language-id="fi_FI">Sanaston asettelu</Name><Name language-id="fr_FR">Disposition du vocabulaire</Name><Name language-id="de_DE">Vokabularlayout</Name><Name language-id="hu_HU">Sz\u00f3t\u00e1r elrendez\u00e9s</Name><Name language-id="ja_JP">\u30dc\u30ad\u30e3\u30d6\u30e9\u30ea\u30ec\u30a4\u30a2\u30a6\u30c8</Name><Name language-id="pt_BR">Layout do vocabul\u00e1rio</Name><Name language-id="es_ES">Dise\u00f1o de vocabulario</Name><Name language-id="sv_SE">Layout f\u00f6r ordlista</Name><Name language-id="zh_TW">Vocabulary Layout</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Description language-id="en_US">Display categories by vocabulary.</Description><Description language-id="ar_SA">\u0639\u0631\u0636 \u0627\u0644\u0641\u0626\u0627\u062a \u062d\u0633\u0628 \u0627\u0644\u0645\u0641\u0631\u062f\u0627\u062a.</Description><Description language-id="ca_ES">Mostra les categories per vocabulari.</Description><Description language-id="zh_CN">\u6309\u8bcd\u6c47\u663e\u793a\u7c7b\u522b\u3002</Description><Description language-id="nl_NL">Categorie\u00ebn weergeven volgens woordenlijst.</Description><Description language-id="fi_FI">N\u00e4ytt\u00f6luokat sanaston mukaan.</Description><Description language-id="fr_FR">Afficher les cat\u00e9gories par vocabulaire.</Description><Description language-id="de_DE">Kategorien nach Vokabular anzeigen.</Description><Description language-id="hu_HU">Kateg\u00f3ri\u00e1k megjelen\u00edt\u00e9se a sz\u00f3t\u00e1rban.</Description><Description language-id="ja_JP">\u30dc\u30ad\u30e3\u30d6\u30e9\u30ea\u3054\u3068\u306b\u30ab\u30c6\u30b4\u30ea\u3092\u8868\u793a\u3057\u307e\u3059\u3002</Description><Description language-id="pt_BR">Exibir categorias por vocabul\u00e1rios.</Description><Description language-id="es_ES">Muestra las categor\u00edas por vocabulario.</Description><Description language-id="sv_SE">Visa kategorier efter ordlista.</Description><Description language-id="zh_TW">Display categories by vocabulary.</Description></root>','ftl','<#macro treeview_item\u000a\u0009cssClassTreeItem = ""\u000a\u0009frequency = 0\u000a\u0009id = ""\u000a\u0009frequencyVisible = true\u000a\u0009name = ""\u000a\u0009selectable = false\u000a\u0009selected = false\u000a\u0009termDisplayContexts = ""\u000a>\u000a\u0009<li class="treeview-item" role="none">\u000a\u0009\u0009<#if name?has_content>\u000a\u0009\u0009\u0009<@liferay_ui.csp>\u000a\u0009\u0009\u0009\u0009<div\u000a\u0009\u0009\u0009\u0009\u0009aria-controls="${(termDisplayContexts?has_content)?then(namespace + ''treeItem'' + id, '''')}"\u000a\u0009\u0009\u0009\u0009\u0009aria-expanded="true"\u000a\u0009\u0009\u0009\u0009\u0009class="treeview-link ${cssClassTreeItem}"\u000a\u0009\u0009\u0009\u0009\u0009data-target="#${namespace}treeItem${id}"\u000a\u0009\u0009\u0009\u0009\u0009data-toggle="collapse"\u000a\u0009\u0009\u0009\u0009\u0009onClick="${namespace}toggleTreeItem(''${namespace}treeItem${id}'');"\u000a\u0009\u0009\u0009\u0009\u0009onKeyPress="${namespace}toggleTreeItemKeypress(event);"\u000a\u0009\u0009\u0009\u0009\u0009role="treeitem"\u000a\u0009\u0009\u0009\u0009\u0009tabindex="${(termDisplayContexts?has_content)?then(0, -1)}"\u000a\u0009\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009\u0009<span class="c-inner" tabindex="-2">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<span class="autofit-row">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if termDisplayContexts?has_content>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="autofit-col">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009aria\-controls="${namespace}treeItem${id}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009aria\-expanded="true"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009aria\-label="${languageUtil.get(locale, ''toggle'')}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClass="btn btn-monospaced component-expander"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009data\-target="#${namespace}treeItem${id}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009data\-toggle="collapse"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009tabindex="-1"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="c-inner" tabindex="-2">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@clay["icon"] symbol="angle-down" />\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@clay["icon"]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClass="component-expanded-d-none"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009symbol="angle-right"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if selectable>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="autofit-col autofit-col-expand">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<div class="custom-checkbox custom-control">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<label>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_ui.csp>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<input\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009${selected?then("checked", "")}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009class="custom-control-input facet-term"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009data-term-id=${id}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009disabled\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009onChange="Liferay.Search.FacetUtil.changeSelection(event);"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009type="checkbox"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</@liferay_ui.csp>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="custom-control-label">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="custom-control-label-text">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009${name}\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if frequencyVisible>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009(${frequency})\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</label>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="autofit-col autofit-col-expand">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="component-text">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009class="text-truncate-inline"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009title="${name}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="text-truncate">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009${name}\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if frequencyVisible>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009(${frequency})\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009</@liferay_ui.csp>\u000a\u0009\u0009</#if>\u000a\u000a\u0009\u0009<#if termDisplayContexts?has_content>\u000a\u0009\u0009\u0009<div class="collapse show" id="${namespace}treeItem${id}">\u000a\u0009\u0009\u0009\u0009<ul class="treeview-group" role="group">\u000a\u0009\u0009\u0009\u0009\u0009<#list termDisplayContexts as termDisplayContext>\u000a\u0009\u0009\u0009\u0009\u0009\u0009<@treeview_item\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClassTreeItem = "tree-item-category"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009frequency = termDisplayContext.getFrequency()\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009frequencyVisible = termDisplayContext.isFrequencyVisible()\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009id = termDisplayContext.getFilterValue()\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009name = htmlUtil.escape(termDisplayContext.getBucketText())\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009selectable = true\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009selected = termDisplayContext.isSelected()\u000a\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009\u0009</#list>\u000a\u0009\u0009\u0009\u0009</ul>\u000a\u0009\u0009\u0009</div>\u000a\u0009\u0009</#if>\u000a\u0009</li>\u000a</#macro>\u000a\u000a<@liferay_ui["panel-container"]\u000a\u0009extended=true\u000a\u0009id="${namespace + ''facetAssetCategoriesPanelContainer''}"\u000a\u0009markupView="lexicon"\u000a\u0009persistState=true\u000a>\u000a\u0009<#assign vocabularyNames = assetCategoriesSearchFacetDisplayContext.getVocabularyNames()![] />\u000a\u000a\u0009<@liferay_ui.panel\u000a\u0009\u0009collapsible=true\u000a\u0009\u0009cssClass="search-facet search-facet-display-vocabulary"\u000a\u0009\u0009id="${namespace + ''facetAssetCategoriesPanel''}"\u000a\u0009\u0009markupView="lexicon"\u000a\u0009\u0009persistState=true\u000a\u0009\u0009title="${(vocabularyNames?size == 1)?then(vocabularyNames[0]!'''', ''category'')}"\u000a\u0009>\u000a\u0009\u0009<#if !assetCategoriesSearchFacetDisplayContext.isNothingSelected()>\u000a\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009cssClass="btn-unstyled c-mb-4 facet-clear-btn"\u000a\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009id="${namespace + ''facetAssetCategoriesClear''}"\u000a\u0009\u0009\u0009\u0009onClick="Liferay.Search.FacetUtil.clearSelections(event);"\u000a\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009<strong>${languageUtil.get(locale, "clear")}</strong>\u000a\u000a\u0009\u0009\u0009\u0009<span class="sr-only">\u000a\u0009\u0009\u0009\u0009\u0009${languageUtil.format(locale, ''x-filter'', ''category-facet-portlet-instance-configuration-name'')}\u000a\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009</#if>\u000a\u000a\u0009\u0009<#if vocabularyNames?has_content>\u000a\u0009\u0009\u0009<ul class="treeview treeview-light treeview-nested treeview-vocabulary-display" role="tree">\u000a\u0009\u0009\u0009\u0009<#list vocabularyNames as vocabularyName>\u000a\u0009\u0009\u0009\u0009\u0009<@treeview_item\u000a\u0009\u0009\u0009\u0009\u0009\u0009cssClassTreeItem = "tree-item-vocabulary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009frequencyVisible = false\u000a\u0009\u0009\u0009\u0009\u0009\u0009id = vocabularyName?replace("[^\\w]|_", '''', ''r'') + vocabularyName?index\u000a\u0009\u0009\u0009\u0009\u0009\u0009name = "${(vocabularyNames?size == 1)?then('''', htmlUtil.escape(vocabularyName))}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009termDisplayContexts = assetCategoriesSearchFacetDisplayContext.getBucketDisplayContexts(vocabularyName)\u000a\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009</#list>\u000a\u0009\u0009\u0009</ul>\u000a\u0009\u0009</#if>\u000a\u0009</@>\u000a</@>\u000a\u000a<@liferay_aui.script>\u000a\u0009function ${namespace}toggleTreeItem(dataTarget) {\u000a\u0009\u0009const dataTargetElements = document.querySelectorAll("[data-target=\"#" + dataTarget + "\"]");\u000a\u000a\u0009\u0009dataTargetElements.forEach(\u000a\u0009\u0009\u0009element => {\u000a\u0009\u0009\u0009\u0009if (element.classList.contains(''collapsed'')) {\u000a\u0009\u0009\u0009\u0009\u0009element.classList.remove(''collapsed'');\u000a\u0009\u0009\u0009\u0009\u0009element.setAttribute(''aria-expanded'', true);\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009else {\u000a\u0009\u0009\u0009\u0009\u0009element.classList.add(''collapsed'');\u000a\u0009\u0009\u0009\u0009\u0009element.setAttribute(''aria-expanded'', false);\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009}\u000a\u0009\u0009);\u000a\u000a\u0009\u0009const subtreeCategoryTreeElement = document.getElementById(dataTarget);\u000a\u000a\u0009\u0009if (subtreeCategoryTreeElement) {\u000a\u0009\u0009\u0009if (subtreeCategoryTreeElement.classList.contains(''show'')) {\u000a\u0009\u0009\u0009\u0009subtreeCategoryTreeElement.classList.remove(''show'');\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009else {\u000a\u0009\u0009\u0009\u0009subtreeCategoryTreeElement.classList.add(''show'');\u000a\u0009\u0009\u0009}\u000a\u0009\u0009}\u000a\u0009}\u000a\u000a\u0009function ${namespace}toggleTreeItemKeypress(event) {\u000a\u0009\u0009event.preventDefault();\u000a\u000a\u0009\u0009if (event.code === ''Enter'' || event.code === ''Space'') {\u000a\u0009\u0009\u0009${namespace}toggleTreeItem(event.target.getAttribute(''aria-controls''));\u000a\u0009\u0009}\u000a\u0009}\u000a</@>',0,20095,NULL,'2025-05-07 00:47:23.485000')
