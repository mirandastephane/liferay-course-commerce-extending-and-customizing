INSERT INTO FRAGMENTENTRYLINK VALUES(128,0,'0ad06364-b1a8-61f5-0184-6326e1efb2cc','0ad06364-b1a8-61f5-0184-6326e1efb2cc',32137,32106,16796623585306,20122,'Clarity Admin','2024-05-20 17:59:59.000000','2026-05-28 13:56:25.507000','','','',32111,20031,12,12,'.component-paragraph img {\u000a\u0009max-width: 100%;\u000a}','<div class="clearfix component-paragraph text-break" data-lfr-editable-id="element-text" data-lfr-editable-type="rich-text">\u000a\u0009<p>\u000a\u0009\u0009A paragraph is a self-contained unit of a discourse in writing dealing with\u000a\u0009\u0009a particular point or idea. Paragraphs are usually an expected part of\u000a\u0009\u0009formal writing, used to organize longer prose.\u000a\u0009</p>\u000a</div>','','','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-text":{"sv_SE":"Granska den angivna URL-adressen och f\u00f6rs\u00f6k att uppdatera sidan. Problemet kan vara tillf\u00e4lligt.","defaultValue":"\n\t<p>\n\t\tA paragraph is a self-contained unit of a discourse in writing dealing with\n\t\ta particular point or idea. Paragraphs are usually an expected part of\n\t\tformal writing, used to organize longer prose.\n\t<\/p>\n\n\n","pt_BR":"Revise o endere\u00e7o de URL digitado e tente atualizar a p\u00e1gina. O problema pode ser tempor\u00e1rio.","ja_JP":"\u5165\u529b\u3057\u305f URL \u30a2\u30c9\u30ec\u30b9\u3092\u78ba\u8a8d\u3057\u3066\u304b\u3089\u30da\u30fc\u30b8\u3092\u66f4\u65b0\u3057\u3066\u307f\u3066\u304f\u3060\u3055\u3044\u3002\u3053\u306e\u554f\u984c\u306f\u4e00\u6642\u7684\u306a\u3082\u306e\u3067\u3042\u308b\u53ef\u80fd\u6027\u304c\u3042\u308a\u307e\u3059\u3002","fr_FR":"V\u00e9rifiez l''URL saisie et essayez d''actualiser la page. Le probl\u00e8me peut \u00eatre temporaire.","hu_HU":"Ellen\u0151rizze a be\u00edrt URL-c\u00edmet, \u00e9s pr\u00f3b\u00e1lja meg friss\u00edteni az oldalt. Lehet, hogy a probl\u00e9ma csak \u00e1tmeneti.","de_DE":"\u00dcberpr\u00fcfen Sie die eingegebene URL-Adresse und versuchen Sie, die Seite zu aktualisieren. Das Problem kann vor\u00fcbergehender Natur sein.","ca_ES":"Reviseu l''adre\u00e7a URL teclejada i intenteu actualitzar la p\u00e0gina. El problema pot ser temporal.","ar_SA":"\u0631\u0627\u062c\u0639 \u0639\u0646\u0648\u0627\u0646 URL \u0627\u0644\u0645\u0643\u062a\u0648\u0628 \u0648\u062c\u0631\u0628 \u062a\u062d\u062f\u064a\u062b \u0627\u0644\u0635\u0641\u062d\u0629. \u0642\u062f \u062a\u0643\u0648\u0646 \u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0645\u0624\u0642\u062a\u0629.","fi_FI":"Tarkista kirjoitettu URL-osoite ja kokeile p\u00e4ivitt\u00e4\u00e4 sivu. Ongelma saattaa olla tilap\u00e4inen.","en_US":"Review the typed URL address and try to refresh the page. The problem may be temporary.","zh_CN":"\u68c0\u67e5\u952e\u5165\u7684 URL \u5730\u5740\u5e76\u5c1d\u8bd5\u5237\u65b0\u9875\u9762\u3002\u95ee\u9898\u53ef\u80fd\u662f\u6682\u65f6\u7684\u3002","es_ES":"Revise la direcci\u00f3n URL introducida e pruebe a actualizar la p\u00e1gina. Es posible que el problema sea temporal.","config":{"mapperType":"link"},"nl_NL":"Controleer de ingevoerde URL en probeer de pagina te vernieuwen. Misschien is het een tijdelijk probleem."}}}','zrxv',1,'BASIC_COMPONENT-paragraph',1,'2026-05-28 13:56:25.507000',NULL)
