INSERT INTO DDMTEMPLATEVERSION VALUES(0,0,94673,20119,16796623585306,20095,NULL,'2024-05-13 14:37:48.093000',31618,0,31619,'1.1','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Name language-id="en_US">Cloud Layout</Name><Name language-id="ar_SA">\u0645\u062e\u0637\u0637 \u0627\u0644\u0633\u062d\u0627\u0628\u0629</Name><Name language-id="ca_ES">Disposici\u00f3 del n\u00favol</Name><Name language-id="zh_CN">\u4e91\u5e03\u5c40</Name><Name language-id="nl_NL">Cloudlay-out</Name><Name language-id="fi_FI">Pilviasettelu</Name><Name language-id="fr_FR">Disposition du cloud</Name><Name language-id="de_DE">Cloudlayout</Name><Name language-id="hu_HU">Felh\u0151 elrendez\u00e9s</Name><Name language-id="ja_JP">\u30af\u30e9\u30a6\u30c9\u306e\u30ec\u30a4\u30a2\u30a6\u30c8</Name><Name language-id="pt_BR">Layout de nuvem</Name><Name language-id="es_ES">Dise\u00f1o de nube</Name><Name language-id="sv_SE">Cloud-layout</Name><Name language-id="zh_TW">\u96f2\u4f48\u5c40</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL,zh_TW," default-locale="en_US"><Description language-id="en_US">Display terms as an inline list of links with varying sizes based on frequency.</Description><Description language-id="ar_SA">\u0639\u0631\u0636 \u0627\u0644\u0645\u0635\u0637\u0644\u062d\u0627\u062a \u0643\u0642\u0627\u0626\u0645\u0629 \u0645\u062f\u0645\u062c\u0629 \u0645\u0646 \u0627\u0644\u0631\u0648\u0627\u0628\u0637 \u0628\u0623\u062d\u062c\u0627\u0645 \u0645\u062e\u062a\u0644\u0641\u0629 \u062a\u0628\u0639\u064b\u0627 \u0644\u0644\u062a\u0631\u062f\u062f.</Description><Description language-id="ca_ES">Mostra els termes com una llista integrada d''enlla\u00e7os amb diverses mides basats en la freq\u00fc\u00e8ncia.</Description><Description language-id="zh_CN">\u5c06\u641c\u7d22\u8bcd\u663e\u793a\u4e3a\u5927\u5c0f\u968f\u9891\u7387\u53d8\u5316\u7684\u5185\u8054\u94fe\u63a5\u5217\u8868\u3002</Description><Description language-id="nl_NL">Termen weergeven als een gealigneerde lijst met links van verschillende lengte op basis van frequentie.</Description><Description language-id="fi_FI">N\u00e4yt\u00e4 termit inline-luettelona koko vaihdellen esiintymistaajuuden mukaan.</Description><Description language-id="fr_FR">Afficher les termes sous la forme d''une liste int\u00e9gr\u00e9e de liens dont les tailles varient en fonction des fr\u00e9quences.</Description><Description language-id="de_DE">Begriffe als eingebettete Linkliste mit unterschiedlichen Gr\u00f6\u00dfen auf Basis der H\u00e4ufigkeit anzeigen.</Description><Description language-id="hu_HU">Jelen\u00edtse meg a kifejez\u00e9seket hivatkoz\u00e1sok sork\u00f6zi list\u00e1jak\u00e9nt a gyakoris\u00e1gt\u00f3l f\u00fcgg\u0151en v\u00e1ltoz\u00f3 m\u00e9retben.</Description><Description language-id="ja_JP">\u7528\u8a9e\u3092\u983b\u5ea6\u306b\u5fdc\u3058\u3066\u30b5\u30a4\u30ba\u304c\u5909\u308f\u308b\u30a4\u30f3\u30e9\u30a4\u30f3\u5f62\u5f0f\u306e\u30ea\u30f3\u30af\u30ea\u30b9\u30c8\u3068\u3057\u3066\u8868\u793a\u3057\u307e\u3059\u3002</Description><Description language-id="pt_BR">Exibir termos como uma lista embutida de links com tamanhos variados baseados pela frequ\u00eancia.</Description><Description language-id="es_ES">Muestra t\u00e9rminos como una lista de enlaces en l\u00ednea con distintos tama\u00f1os basados en la frecuencia.</Description><Description language-id="sv_SE">Visa villkoren som en infogad lista med l\u00e4nkar med olika storlekar baserat p\u00e5 frekvens.</Description><Description language-id="zh_TW">\u5c07\u689d\u6b3e\u986f\u793a\u70ba\u9023\u7d50\u7684\u884c\u5167\u5217\u8868\uff0c\u9019\u4e9b\u9023\u7d50\u7684\u5927\u5c0f\u6839\u64da\u983b\u7387\u800c\u8b8a\u5316\u3002</Description></root>','ftl','<style ${nonceAttribute} type="text/css">\u000a\u0009.tag-cloud .facet-term {\u000a\u0009\u0009line-height: 1.2;\u000a\u0009}\u000a</style>\u000a\u000a<@liferay_ui["panel-container"]\u000a\u0009extended=true\u000a\u0009id="${namespace + ''facetAssetCategoriesPanelContainer''}"\u000a\u0009markupView="lexicon"\u000a\u0009persistState=true\u000a>\u000a\u0009<@liferay_ui.panel\u000a\u0009\u0009collapsible=true\u000a\u0009\u0009cssClass="search-facet"\u000a\u0009\u0009id="${namespace + ''facetAssetCategoriesPanel''}"\u000a\u0009\u0009markupView="lexicon"\u000a\u0009\u0009persistState=true\u000a\u0009\u0009title="category"\u000a\u0009>\u000a\u0009\u0009<#if !assetCategoriesSearchFacetDisplayContext.isNothingSelected()>\u000a\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009cssClass="btn-unstyled c-mb-4 facet-clear-btn"\u000a\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009id="${namespace + ''facetAssetCategoriesClear''}"\u000a\u0009\u0009\u0009\u0009onClick="Liferay.Search.FacetUtil.clearSelections(event);"\u000a\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009<strong>${languageUtil.get(locale, "clear")}</strong>\u000a\u000a\u0009\u0009\u0009\u0009<span class="sr-only">\u000a\u0009\u0009\u0009\u0009\u0009${languageUtil.format(locale, ''x-filter'', ''category-facet-portlet-instance-configuration-name'')}\u000a\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009</#if>\u000a\u000a\u0009\u0009<ul class="list-unstyled tag-cloud">\u000a\u0009\u0009\u0009<#if entries?has_content>\u000a\u0009\u0009\u0009\u0009<#list entries as entry>\u000a\u0009\u0009\u0009\u0009\u0009<span class="facet-value">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClass="btn-unstyled facet-term ${(entry.isSelected())?then(''facet-term-selected'', ''facet-term-unselected'')} tag-popularity-${entry.getPopularity()} term-name"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009data\-term\-id="${entry.getFilterValue()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009disabled="true"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009onClick="Liferay.Search.FacetUtil.changeSelection(event);"\u000a\u0009\u0009\u0009\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if entry.isSelected()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<strong>${htmlUtil.escape(entry.getBucketText())}</strong>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009${htmlUtil.escape(entry.getBucketText())}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009</#list>\u000a\u0009\u0009\u0009</#if>\u000a\u0009\u0009</ul>\u000a\u0009</@>\u000a</@>',0,20095,NULL,'2024-05-13 14:37:48.093000')
