INSERT INTO FRAGMENTENTRYLINK VALUES(129,0,'ec9347b1-6415-abc8-20b6-a830a309b132','ec9347b1-6415-abc8-20b6-a830a309b132',34171,32106,16796623585306,20122,'Clarity Admin','2024-05-20 20:34:23.000000','2026-05-29 22:26:34.498000','','','',93616,20031,26,26,'.component-html img {\u000a\u0009max-width: 100%;\u000a}','<div class="component-html" data-lfr-editable-id="element-html" data-lfr-editable-type="html">\u000a\u0009<h1>HTML Example</h1>\u000a\u000a\u0009<p class="mb-0">\u000a\u0009\u0009A paragraph is a <strong>self-contained</strong> unit of a discourse in\u000a\u0009\u0009writing dealing with a particular point or <em>idea</em>. Paragraphs are\u000a\u0009\u0009usually an expected part of formal writing, used to organize longer\u000a\u0009\u0009prose.\u000a\u0009</p>\u000a</div>','','','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-html":{"defaultValue":"\n\t<h1>HTML Example<\/h1>\n\n\t<p class=\"mb-0\">\n\t\tA paragraph is a <strong>self-contained<\/strong> unit of a discourse in\n\t\twriting dealing with a particular point or <em>idea<\/em>. Paragraphs are\n\t\tusually an expected part of formal writing, used to organize longer\n\t\tprose.\n\t<\/p>\n","en_US":"\n<h1>\n  Everyone has <br/>their own <span class=\"text-primary\">Clarity<\/span>\n<\/h1>\n","config":{}}}}','ovol',0,'BASIC_COMPONENT-html',1,'2026-05-29 22:26:34.498000',NULL)
