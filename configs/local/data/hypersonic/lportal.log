09\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009],\u000a\u0009\u0009\u0009"label": "heading-options"\u000a\u0009\u0009}\u000a\u0009]\u000a}','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-text":{"defaultValue":"\n\tHeading Example\n","en_US":"Join the Team!","config":{"mapperType":"link"}}},"com.liferay.fragment.entry.processor.freemarker.FreeMarkerFragmentEntryProcessor":{"headingLevel":"h1"}}','buwm',0,'BASIC_COMPONENT-heading',1,'2026-04-10 17:40:38.487000',NULL)
